# ─────────────────────────────────────────────────────────────────────────────
# docker/.env.example — shapeguard local dev environment
#
# Copy this file to docker/.env and fill in real values.
# Never commit docker/.env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# Redis Commander web UI credentials (--profile tools only)
REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=changeme

# Optional: Stripe webhook secret for with-webhook example
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Optional: GitHub webhook secret
GITHUB_WEBHOOK_SECRET=your_github_secret_here
