# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — shapeguard
# ─────────────────────────────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
website/node_modules/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
coverage/
website/build/
website/.docusaurus/

# ── Environment ───────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
docker/.env           # real credentials — only commit docker/.env.example

# ── Editor ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Test output ───────────────────────────────────────────────────────────────
.vitest-cache/

# ── npm pack output ───────────────────────────────────────────────────────────
*.tgz

# ── Intermediate build dirs ───────────────────────────────────────────────────
dist-new/
dist-ts/
