{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "lib":              ["ES2020"],
    "types":            ["node"],
    "strict":           true,
    "noUncheckedIndexedAccess":   true,
    "noImplicitOverride":         true,
    "declaration":      true,
    "declarationMap":   true,
    "sourceMap":        true,
    "outDir":           "./dist",
    "rootDir":          "./src",
    "skipLibCheck":     true,
    "esModuleInterop":  true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
